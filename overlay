/* ── TRANSFORM CONTROLS ────────────────────────────────────────── */
.xform-block { border-bottom:1px solid rgba(255,255,255,.06); padding-bottom:12px; }
.xform-block:last-child { border-bottom:none; padding-bottom:0; }
.xform-row { display:grid; grid-template-columns:auto 1fr; gap:4px 10px; align-items:center; margin-bottom:6px; }
