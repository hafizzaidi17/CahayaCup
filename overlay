<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cahaya Cup — Live Stream Overlays</title>
<style>
@font-face {
  font-family:'Oswald';
  src:url('data:font/truetype;base64,') format('truetype');
  font-weight:200 700; font-display:block;
}
@font-face {
  font-family:'Saira';
  src:url('data:font/truetype;base64,') format('truetype');
  font-weight:100 900; font-display:block;
}

/* ── TOKENS ───────────────────────────────────────────────────────────── */
:root {
  --home-color:    #1A2DBE;
  --away-color:    #070C4A;
  --olive:         #f45a0c;
  --home-bar:      #69E2A6;
  --away-bar:      #E7356C;
  --loc-text:      #08197B;
  --paper:         #F4F6F4;
  --fd:            'Oswald', 'Arial Narrow', sans-serif;
  --fb:            'Saira', sans-serif;
  /* derived panel gradients — updated by JS when colors change */
  --home-grad: linear-gradient(118deg, #0D1A6E 0%, #090F45 42%, #07103A 70%, #040924 100%);
  --away-grad: linear-gradient(242deg, #070C4A 0%, #050930 42%, #040724 70%, #030519 100%);
}

*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
html,body { width:100%; height:100%; overflow:hidden; background:#0d0f1a; font-family:var(--fb); }

/* ══════════════════════════════════════════════════════════════════════
   OVERLAY CANVAS  (1920×1080, transparent, absolute-positioned)
   lives inside both the preview pane AND the full stream view
══════════════════════════════════════════════════════════════════════ */
.oc {
  position:relative;
  width:1920px; height:1080px;
  background:transparent;
  overflow:hidden;
  transform-origin:top left;
  flex-shrink:0;
}

/* ── KEYFRAMES ─────────────────────────────────────────────────────── */
@keyframes wipe-r    { from{clip-path:inset(0 100% 0 0)} to{clip-path:inset(0 0 0 0)} }
@keyframes wipe-l    { from{clip-path:inset(0 0 0 100%)} to{clip-path:inset(0 0 0 0)} }
@keyframes wipe-cx   { from{clip-path:inset(0 50% 0 50%)} to{clip-path:inset(0 0 0 0)} }
@keyframes sy-in     { from{transform:scaleY(0)} to{transform:scaleY(1)} }
@keyframes fade      { from{opacity:0} to{opacity:1} }
@keyframes slide-l   { from{transform:translateX(-52px);opacity:0} to{transform:translateX(0);opacity:1} }
@keyframes slide-r   { from{transform:translateX(52px);opacity:0} to{transform:translateX(0);opacity:1} }
@keyframes pop       { 0%{transform:scale(0.4) translateY(-18px);opacity:0} 68%{transform:scale(1.07) translateY(2px)} 100%{transform:scale(1) translateY(0);opacity:1} }
@keyframes spop      { 0%{transform:scale(0)} 65%{transform:scale(1.22)} 100%{transform:scale(1)} }
@keyframes card-l    { from{transform:translateX(-130px);opacity:0} to{transform:translateX(0);opacity:1} }
@keyframes card-r    { from{transform:translateX(130px);opacity:0} to{transform:translateX(0);opacity:1} }
@keyframes sy-up     { from{transform:scaleY(0.65);opacity:0} to{transform:scaleY(1);opacity:1} }
@keyframes fslide-u  { from{transform:translateY(16px);opacity:0} to{transform:translateY(0);opacity:1} }
/* exit */
@keyframes wipe-r-o  { from{clip-path:inset(0 0 0 0)} to{clip-path:inset(0 100% 0 0)} }
@keyframes wipe-l-o  { from{clip-path:inset(0 0 0 0)} to{clip-path:inset(0 0 0 100%)} }
@keyframes wipe-cx-o { from{clip-path:inset(0 0 0 0)} to{clip-path:inset(0 50% 0 50%)} }
@keyframes sy-out    { from{transform:scaleY(1)} to{transform:scaleY(0)} }
@keyframes fade-o    { from{opacity:1} to{opacity:0} }
@keyframes slide-l-o { from{transform:translateX(0);opacity:1} to{transform:translateX(-52px);opacity:0} }
@keyframes slide-r-o { from{transform:translateX(0);opacity:1} to{transform:translateX(52px);opacity:0} }
@keyframes pop-o     { from{transform:scale(1);opacity:1} to{transform:scale(0.3);opacity:0} }
@keyframes card-l-o  { from{transform:translateX(0);opacity:1} to{transform:translateX(-130px);opacity:0} }
@keyframes card-r-o  { from{transform:translateX(0);opacity:1} to{transform:translateX(130px);opacity:0} }

/* ── GRAPHIC VISIBILITY ────────────────────────────────────────────── */
.g { position:absolute; inset:0; pointer-events:none; display:none; }
.g.on  { display:block; }

/* animation state machine: .on = entry, .out = exit */
/* Transitions are driven by adding/removing classes, keyframe restart via JS reflow */

/* ══════════════════════════════════════════════════════════════════════
   G1 — INTRO
══════════════════════════════════════════════════════════════════════ */
.g-intro { font-family:var(--fd); }

.ic { /* intro card */
  position:absolute;
  top:212px; width:540px; height:624px; border-radius:44px;
  display:flex; flex-direction:column; align-items:center;
  justify-content:space-between; padding:64px 0 54px;
  overflow:hidden;
  box-shadow:0 18px 50px rgba(0,0,0,.4);
  opacity:0;
}
.ic-h { left:-44px; background:var(--home-grad); }
.ic-a { right:-44px; background:var(--away-grad); }

.on .ic-h { animation:card-l .55s cubic-bezier(.22,.6,.36,1) .05s both; }
.on .ic-a { animation:card-r .55s cubic-bezier(.22,.6,.36,1) .12s both; }
.out .ic-h { animation:card-l-o .38s ease-in 0s both; }
.out .ic-a { animation:card-r-o .38s ease-in .04s both; }


.ic-name {
  color:#fff; font-weight:600; font-size:62px; letter-spacing:1px;
  text-transform:uppercase; line-height:1; opacity:0;
}
.intro-name-only {
  font-size:72px; letter-spacing:1px;
  width:100%; text-align:center;
  word-break:break-word; overflow-wrap:break-word;
  white-space:normal; padding:0 32px;
  line-height:1.1;
}
/* Intro cards are name-only: override space-between → center */
.g-intro .ic {
  justify-content:center;
}
.on  .ic-name { animation:fslide-u .38s ease-out .58s both; }
.out .ic-name { animation:fade-o .25s ease-in 0s both; }

.i-panel {
  position:absolute; left:600px; top:300px; width:720px; height:462px;
  background:var(--paper); opacity:0; transform-origin:center;
}
.on  .i-panel { animation:sy-up .44s cubic-bezier(.22,.6,.36,1) .28s both; }
.out .i-panel { animation:fade-o .3s ease-in 0s both; }

.i-crest {
  position:absolute; left:calc(960px - 150px); top:130px;
  width:300px; height:360px; object-fit:contain;
  opacity:0; transform-origin:bottom center;
  filter:drop-shadow(0 4px 8px rgba(0,0,0,.3)); z-index:8;
}
.on  .i-crest { animation:pop .52s cubic-bezier(.34,1.5,.64,1) .4s both; }
.out .i-crest { animation:pop-o .3s ease-in 0s both; }

.i-cahaya {
  position:absolute; left:calc(960px - 290px); top:545px;
  width:580px; object-fit:contain; opacity:0; z-index:4;
}
.on  .i-cahaya { animation:fade .38s ease-out .56s both; }
.out .i-cahaya { animation:fade-o .28s ease-in 0s both; }

.i-loc {
  position:absolute; left:260px; top:902px; width:1400px; height:54px;
  background:var(--olive);
  display:flex; align-items:center; justify-content:center;
  clip-path:inset(0 50% 0 50%); z-index:6;
}
.on  .i-loc { animation:wipe-cx .48s cubic-bezier(.22,.6,.36,1) .72s both; }
.out .i-loc { animation:wipe-cx-o .35s ease-in 0s both; }
.i-loc span {
  font-family:var(--fb); color:#f5f7f6;
  font-weight:600; font-size:30px; letter-spacing:.4px; opacity:0;
}
.on  .i-loc span { animation:fade .28s ease-out .88s both; }
.out .i-loc span { animation:fade-o .2s ease-in 0s both; }

/* ══════════════════════════════════════════════════════════════════════
   G2 — MATCH / G3 — SCOREBUG   (shared lower-third shell)
══════════════════════════════════════════════════════════════════════ */
.lt {
  position:absolute;
  left:240px; top:812px; width:1440px;
  font-family:var(--fd);
}

.lt-row {
  position:relative; height:96px;
  display:flex; overflow:visible;
}

.lt-h, .lt-a {
  height:100%; width:596px; flex:none;
  display:flex; align-items:center; overflow:hidden;
}
.lt-h { background:var(--home-grad); clip-path:inset(0 100% 0 0); }
.lt-a { background:var(--away-grad); clip-path:inset(0 0 0 100%); }
.lt-a { margin-left:248px; } /* push past centre tab */

.on  .lt-h { animation:wipe-r .42s cubic-bezier(.22,.6,.36,1) 0s both; }
.on  .lt-a { animation:wipe-l .42s cubic-bezier(.22,.6,.36,1) .04s both; }
.out .lt-h { animation:wipe-r-o .3s ease-in 0s both; }
.out .lt-a { animation:wipe-l-o .3s ease-in .02s both; }

.lt-hi, .lt-ai {
  display:flex; align-items:center; justify-content:space-between;
  flex-direction:row;
  width:100%; padding:0 40px 0 36px; opacity:0;
}

.on  .lt-hi { animation:slide-l .34s ease-out .38s both; }
.on  .lt-ai { animation:slide-r .34s ease-out .40s both; }
.out .lt-hi { animation:slide-l-o .24s ease-in 0s both; }
.out .lt-ai { animation:slide-r-o .24s ease-in .02s both; }

.lt-name {
  color:#fff; font-weight:600; font-size:52px;
  letter-spacing:.5px; text-transform:uppercase;
  line-height:1; white-space:nowrap;
}
/* Match LT: away name only → push to right so it mirrors home layout */
#g-match .lt-ai .lt-name { margin-left:auto; }
#g-match .lt-ai { padding:0 40px 0 36px; }
.lt-score {
  color:#fff; font-weight:700; font-size:63px; line-height:1;
}

/* score update flash — doesn't disturb resting scale(1) */
.score-flash { animation:spop .35s cubic-bezier(.34,1.5,.64,1) both !important; }

.on  .lt-score { animation:spop .34s cubic-bezier(.34,1.5,.64,1) .56s both; transform:scale(1); }
.out .lt-score { animation:fade-o .18s ease-in 0s both; }

/* center tab */
.lt-tab {
  position:absolute; left:50%; top:0;
  width:248px; height:100%;
  background:var(--paper);
  display:flex; align-items:center; justify-content:center;
  z-index:6;
  transform:translateX(-50%) scaleY(0);
  transform-origin:center;
}
.on  .lt-tab { animation:lt-tab-e .36s cubic-bezier(.22,.6,.36,1) .2s both; }
.out .lt-tab { animation:lt-tab-x .26s ease-in 0s both; }
@keyframes lt-tab-e { to{transform:translateX(-50%) scaleY(1);} }
@keyframes lt-tab-x { to{transform:translateX(-50%) scaleY(0);} }

.lt-tab img { width:88%; object-fit:contain; opacity:0; }
.on  .lt-tab img { animation:fade .26s ease-out .38s both; }
.out .lt-tab img { animation:fade-o .18s ease-in 0s both; }

/* teal / pink slivers */
.lt-tl, .lt-pk {
  position:absolute; top:0; height:100%; width:16px;
  transform:scaleY(0); transform-origin:center; z-index:7;
}
.lt-tl { left:calc(50% - 124px - 16px); background:var(--home-bar); }
.lt-pk { left:calc(50% + 124px);        background:var(--away-bar); }
.on  .lt-tl, .on  .lt-pk { animation:sy-in  .28s cubic-bezier(.22,.6,.36,1) .28s both; }
.out .lt-tl, .out .lt-pk { animation:sy-out .2s ease-in 0s both; }

/* crest floating above tab */
.lt-crest {
  position:absolute; left:50%;
  top:0;
  width:130px; height:158px;
  object-fit:contain; opacity:0;
  transform:translateX(-50%) translateY(-105%) scale(.4);
  transform-origin:bottom center;
  filter:drop-shadow(0 3px 6px rgba(0,0,0,.35));
  z-index:9;
}
.on  .lt-crest { animation:lt-cr-e .48s cubic-bezier(.34,1.44,.64,1) .32s both; }
.out .lt-crest { animation:lt-cr-x .28s ease-in 0s both; }
@keyframes lt-cr-e { to{transform:translateX(-50%) translateY(-105%) scale(1); opacity:1;} }
@keyframes lt-cr-x { to{transform:translateX(-50%) translateY(-105%) scale(.35); opacity:0;} }

/* olive sub-bar */
.lt-olive {
  height:46px; background:var(--olive);
  display:flex; align-items:center; justify-content:center;
  transform:scaleY(0); transform-origin:top;
}
.on  .lt-olive { animation:sy-in  .34s cubic-bezier(.22,.6,.36,1) .3s both; }
.out .lt-olive { animation:sy-out .24s ease-in 0s both; }
.lt-olive span {
  font-family:var(--fb); color:#f5f7f6;
  font-weight:600; font-size:27px; letter-spacing:.3px; opacity:0;
}
.on  .lt-olive span { animation:fade .28s ease-out .5s both; }
.out .lt-olive span { animation:fade-o .18s ease-in 0s both; }

/* ══════════════════════════════════════════════════════════════════════
   G4 — SCOREBOARD (compact top-left)
══════════════════════════════════════════════════════════════════════ */
.sb {
  position:absolute; top:74px; left:132px;
  width:560px; font-family:var(--fd);
}

.sb-row {
  position:relative; height:88px;
  display:flex; overflow:visible;
}
.sb-h, .sb-a {
  height:100%; width:205px; flex:none;
  display:flex; align-items:center; overflow:hidden;
}
.sb-h { background:var(--home-grad); clip-path:inset(0 100% 0 0); }
.sb-a { background:var(--away-grad); clip-path:inset(0 0 0 100%); }
.sb-a { margin-left:150px; } /* push past centre tab */

.on  .sb-h { animation:wipe-r .38s cubic-bezier(.22,.6,.36,1) 0s both; }
.on  .sb-a { animation:wipe-l .38s cubic-bezier(.22,.6,.36,1) .04s both; }
.out .sb-h { animation:wipe-r-o .28s ease-in 0s both; }
.out .sb-a { animation:wipe-l-o .28s ease-in .02s both; }

.sb-hi, .sb-ai {
  display:flex; align-items:center; justify-content:space-between;
  width:100%; padding:0 16px 0 22px; opacity:0;
}
.sb-ai { padding:0 22px 0 16px; }
.on  .sb-hi { animation:slide-l .28s ease-out .34s both; }
.on  .sb-ai { animation:slide-r .28s ease-out .36s both; }
.out .sb-hi { animation:slide-l-o .2s ease-in 0s both; }
.out .sb-ai { animation:slide-r-o .2s ease-in .02s both; }

.sb-abbr  { color:#fff; font-weight:600; font-size:44px; letter-spacing:1px; line-height:1; }
.sb-score { color:#fff; font-weight:700; font-size:50px; line-height:1; }
.on  .sb-score { animation:spop .3s cubic-bezier(.34,1.5,.64,1) .50s both; transform:scale(1); }
.out .sb-score { animation:fade-o .16s ease-in 0s both; }

.sb-tab {
  position:absolute; left:50%; top:0;
  width:150px; height:100%;
  background:var(--paper);
  display:flex; align-items:center; justify-content:center;
  z-index:6;
  transform:translateX(-50%) scaleY(0); transform-origin:center;
}
.on  .sb-tab { animation:lt-tab-e .33s cubic-bezier(.22,.6,.36,1) .17s both; }
.out .sb-tab { animation:lt-tab-x .22s ease-in 0s both; }
.sb-tab img { width:90%; object-fit:contain; opacity:0; }
.on  .sb-tab img { animation:fade .22s ease-out .34s both; }
.out .sb-tab img { animation:fade-o .16s ease-in 0s both; }

.sb-tl, .sb-pk {
  position:absolute; top:0; height:100%; width:12px;
  transform:scaleY(0); transform-origin:center; z-index:7;
}
.sb-tl { left:calc(50% - 75px - 12px); background:var(--home-bar); }
.sb-pk { left:calc(50% + 75px);        background:var(--away-bar); }
.on  .sb-tl,.on  .sb-pk { animation:sy-in  .26s cubic-bezier(.22,.6,.36,1) .26s both; }
.out .sb-tl,.out .sb-pk { animation:sy-out .18s ease-in 0s both; }

.sb-crest {
  position:absolute; left:50%;
  top:0; width:68px; height:86px;
  object-fit:contain; opacity:0;
  transform:translateX(-50%) translateY(-82%) scale(.4);
  transform-origin:bottom center;
  filter:drop-shadow(0 2px 5px rgba(0,0,0,.4)); z-index:9;
}
.on  .sb-crest { animation:sb-cr-e .44s cubic-bezier(.34,1.44,.64,1) .26s both; }
.out .sb-crest { animation:sb-cr-x .24s ease-in 0s both; }
@keyframes sb-cr-e { to{transform:translateX(-50%) translateY(-82%) scale(1); opacity:1;} }
@keyframes sb-cr-x { to{transform:translateX(-50%) translateY(-82%) scale(.35); opacity:0;} }

.sb-olive {
  height:42px; background:var(--olive);
  display:flex; align-items:center; position:relative;
  transform:scaleY(0); transform-origin:top;
}
.on  .sb-olive { animation:sy-in  .3s cubic-bezier(.22,.6,.36,1) .26s both; }
.out .sb-olive { animation:sy-out .2s ease-in 0s both; }
.sb-period, .sb-clock {
  font-family:var(--fd); color:#f5f7f6;
  font-weight:600; letter-spacing:1px; opacity:0;
}
.on  .sb-period,.on  .sb-clock { animation:fade .22s ease-out .45s both; }
.out .sb-period,.out .sb-clock { animation:fade-o .16s ease-in 0s both; }
.sb-period { position:absolute; left:18px; font-size:22px; }
.sb-clock  { position:absolute; left:50%; transform:translateX(-50%); font-size:28px; font-weight:700; transition:opacity .12s; }

/* ══════════════════════════════════════════════════════════════════════
   LAYOUT  — panel + embedded preview
══════════════════════════════════════════════════════════════════════ */
#app {
  display:flex; flex-direction:column;
  width:100vw; height:100vh;
  overflow:hidden;
}

/* ─ top bar ─ */
#topbar {
  flex-shrink:0; height:52px;
  background:linear-gradient(90deg,#0a1372,#1a2dbe);
  display:flex; align-items:center; gap:14px; padding:0 22px;
  border-bottom:1px solid rgba(105,226,166,.25);
}
#topbar img { height:36px; object-fit:contain; filter:drop-shadow(0 2px 4px rgba(0,0,0,.4)); }
#topbar h1 { font-family:'Oswald'; color:#fff; font-size:18px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; }
#topbar .spacer { flex:1; }
.status-pill {
  display:flex; align-items:center; gap:7px;
  background:rgba(0,0,0,.3); border-radius:20px;
  padding:5px 13px; font-size:12px; font-weight:700;
  letter-spacing:1px; text-transform:uppercase; color:rgba(255,255,255,.5);
  border:1px solid rgba(255,255,255,.1);
}
.status-dot { width:8px; height:8px; border-radius:50%; background:rgba(255,255,255,.2); transition:background .3s; }
.status-dot.live { background:#69E2A6; box-shadow:0 0 8px #69E2A6; animation:pulse 1.4s ease-in-out infinite; }
@keyframes pulse { 0%,100%{box-shadow:0 0 4px #69E2A6} 50%{box-shadow:0 0 14px #69E2A6} }
#btn-stream-view {
  background:rgba(105,226,166,.12); border:1px solid rgba(105,226,166,.35);
  border-radius:8px; color:#69E2A6; font-family:'Oswald'; font-size:13px;
  font-weight:600; letter-spacing:.5px; text-transform:uppercase;
  padding:7px 16px; cursor:pointer; transition:all .18s;
}
#btn-stream-view:hover { background:rgba(105,226,166,.22); }

/* ─ main area = controls (left) + preview (right) ─ */
#main {
  flex:1; display:flex; min-height:0;
}

/* ─ controls ─ */
#controls {
  width:380px; flex-shrink:0;
  overflow-y:auto; padding:16px;
  display:flex; flex-direction:column; gap:12px;
  border-right:1px solid rgba(255,255,255,.07);
  scrollbar-width:thin; scrollbar-color:rgba(255,255,255,.15) transparent;
}
.card {
  background:#151929; border:1px solid rgba(255,255,255,.07);
  border-radius:12px; padding:16px;
}
.card-title {
  font-family:'Oswald'; color:#69E2A6; font-size:12px; font-weight:600;
  text-transform:uppercase; letter-spacing:1.5px; margin-bottom:13px;
  display:flex; align-items:center; gap:7px;
}
.card-title::before { content:''; display:inline-block; width:7px; height:7px; border-radius:50%; background:#69E2A6; flex-shrink:0; }

.field { display:flex; flex-direction:column; gap:3px; margin-bottom:10px; }
.field:last-child { margin-bottom:0; }
.field label { color:rgba(255,255,255,.45); font-size:10px; letter-spacing:.8px; text-transform:uppercase; }
.field input[type=text], .field input[type=number] {
  background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.11);
  border-radius:7px; color:#fff; font-family:'Saira'; font-size:14px;
  padding:7px 11px; outline:none; transition:border-color .18s;
  width:100%;
}
.field input:focus { border-color:#69E2A6; background:rgba(105,226,166,.05); }

/* color picker row */
.color-row {
  display:flex; gap:10px; align-items:flex-end;
}
.color-field { flex:1; display:flex; flex-direction:column; gap:4px; }
.color-field label { color:rgba(255,255,255,.45); font-size:10px; letter-spacing:.8px; text-transform:uppercase; }
.color-swatch {
  width:100%; height:38px; border-radius:7px; border:2px solid rgba(255,255,255,.12);
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  gap:8px; font-family:'Oswald'; font-size:13px; font-weight:600; color:#fff;
  letter-spacing:.5px; text-transform:uppercase; position:relative; overflow:hidden;
  transition:border-color .18s;
}
.color-swatch:hover { border-color:rgba(255,255,255,.3); }
.color-swatch input[type=color] {
  position:absolute; inset:0; width:100%; height:100%;
  opacity:0; cursor:pointer; border:none; padding:0;
}

/* score stepper */
.stepper { display:flex; align-items:center; width:fit-content; }
.step-btn {
  width:34px; height:34px; background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.12); border-radius:6px;
  color:#fff; font-size:18px; font-family:'Oswald'; cursor:pointer; transition:background .15s;
  display:flex; align-items:center; justify-content:center; line-height:1;
}
.step-btn:hover { background:rgba(105,226,166,.2); color:#69E2A6; border-color:#69E2A6; }
.step-val { font-family:'Oswald'; font-weight:700; font-size:26px; color:#fff; min-width:44px; text-align:center; }

/* period pills */
.pills { display:flex; flex-wrap:wrap; gap:6px; }
.pill {
  background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.13);
  border-radius:6px; color:rgba(255,255,255,.65); font-family:'Oswald';
  font-size:13px; font-weight:600; padding:5px 12px; cursor:pointer;
  transition:all .17s; text-transform:uppercase; letter-spacing:.4px;
}
.pill:hover { background:rgba(26,45,190,.5); color:#fff; border-color:#1A2DBE; }
.pill.act { border-color:#69E2A6; color:#fff; background:rgba(26,45,190,.7); }

/* clock */
.clock-face {
  font-family:'Oswald'; font-weight:700; font-size:46px; color:#fff;
  letter-spacing:2px; text-align:center; padding:8px 0;
  background:rgba(255,255,255,.04); border-radius:8px; margin-bottom:8px;
}
.clock-btns { display:flex; gap:7px; }
.cbtn {
  flex:1; height:36px; border-radius:7px;
  border:1px solid rgba(255,255,255,.13); cursor:pointer;
  font-family:'Oswald'; font-weight:600; font-size:13px; letter-spacing:.4px;
  text-transform:uppercase; background:rgba(255,255,255,.07);
  color:rgba(255,255,255,.75); transition:all .17s;
}
.cbtn:hover { background:rgba(105,226,166,.15); border-color:#69E2A6; color:#69E2A6; }
.cbtn.running { background:rgba(231,53,108,.15); border-color:#E7356C; color:#E7356C; }

/* graphic buttons */
.g-btns { display:flex; flex-direction:column; gap:8px; }
.g-row { display:flex; gap:8px; }
.btn-on, .btn-off {
  flex:1; height:42px; border-radius:9px; border:none;
  cursor:pointer; font-family:'Oswald'; font-weight:600; font-size:15px;
  letter-spacing:.4px; text-transform:uppercase; transition:all .17s;
  display:flex; align-items:center; justify-content:center; gap:7px;
}
.btn-on {
  background:linear-gradient(135deg,#1A2DBE,#0A1372);
  color:#fff; border:1px solid rgba(105,226,166,.25);
}
.btn-on:hover  { filter:brightness(1.18); border-color:#69E2A6; }
.btn-on:active { transform:scale(.97); }
.btn-off {
  background:rgba(255,255,255,.06); color:rgba(255,255,255,.45);
  border:1px solid rgba(255,255,255,.1);
}
.btn-off:hover  { background:rgba(231,53,108,.12); color:#E7356C; border-color:#E7356C; }
.btn-off:active { transform:scale(.97); }
.btn-all-off {
  width:100%; height:38px; background:rgba(231,53,108,.1);
  border:1px solid rgba(231,53,108,.3); border-radius:9px;
  color:#E7356C; font-family:'Oswald'; font-weight:600; font-size:14px;
  letter-spacing:.5px; text-transform:uppercase; cursor:pointer; transition:all .17s;
}
.btn-all-off:hover { background:rgba(231,53,108,.22); }

/* keyboard hint */
.kbd { display:inline-block; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.2); border-radius:4px; padding:1px 6px; font-size:11px; color:rgba(255,255,255,.5); font-family:monospace; }

/* ─ preview pane ─ */
