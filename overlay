              <div class="lt-tl"></div><div class="lt-pk"></div>
              <img class="lt-crest" src="data:image/png;base64," alt="">
              <div class="lt-a">
                <div class="lt-ai">
                  <span class="lt-score" id="sbug-as">0</span>
                  <span class="lt-name" id="sbug-a">TEAM DEF</span>
                </div>
              </div>
            </div>
            <div class="lt-olive"><span id="sbug-loc">Live from Selangor Polo Club</span></div>
          </div>

          <!-- G4: SCOREBOARD -->
          <div class="g sb" id="g-scoreboard">
            <div class="sb-row">
              <div class="sb-h">
                <div class="sb-hi">
                  <span class="sb-abbr" id="sb-ha">ABC</span>
                  <span class="sb-score" id="sb-hs">0</span>
                </div>
              </div>
              <div class="sb-tab"><img src="data:image/png;base64," alt=""></div>
              <div class="sb-tl"></div><div class="sb-pk"></div>
              <img class="sb-crest" src="data:image/png;base64," alt="">
              <div class="sb-a">
                <div class="sb-ai">
                  <span class="sb-score" id="sb-as">0</span>
                  <span class="sb-abbr" id="sb-aa">DEF</span>
                </div>
              </div>
            </div>
            <div class="sb-olive">
              <span class="sb-period" id="sb-period">1ST</span>
              <span class="sb-clock"  id="sb-clock">00:00</span>
            </div>
          </div>

        </div><!-- /oc -->
      </div><!-- /preview-pane -->
    </div><!-- /preview -->

  </div><!-- /main -->
</div><!-- /app -->

<script>
/* ═══════════════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════════════ */
const S = {
  homeScore:0, awayScore:0, period:'1ST',
  mm:0, ss:0, running:false, iv:null,
  live: new Set()
};

/* ═══════════════════════════════════════════════════════════════
   SCALE CANVAS TO FIT PREVIEW PANE
═══════════════════════════════════════════════════════════════ */
function scaleOC() {
  const pane = document.getElementById('preview-pane');
  const oc   = document.getElementById('oc');
  if (!pane || !oc) return;
  const pw = pane.clientWidth, ph = pane.clientHeight;
  const scale = Math.min(pw/1920, ph/1080);
  oc.style.transform = `scale(${scale})`;
  // center it
  oc.style.left = Math.max(0,(pw - 1920*scale)/2) + 'px';
  oc.style.top  = Math.max(0,(ph - 1080*scale)/2) + 'px';
}
window.addEventListener('resize', scaleOC);
window.addEventListener('load', scaleOC);
setTimeout(scaleOC, 100);

/* ═══════════════════════════════════════════════════════════════
   COLOR CHANGE — rebuilds CSS gradients instantly
═══════════════════════════════════════════════════════════════ */
function hexDarken(hex, factor) {
  // factor 0=black, 1=original
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  const dr = Math.round(r*factor), dg = Math.round(g*factor), db = Math.round(b*factor);
  return `#${dr.toString(16).padStart(2,'0')}${dg.toString(16).padStart(2,'0')}${db.toString(16).padStart(2,'0')}`;
}
function buildGrad(hex, dir) {
  const mid   = hexDarken(hex, 0.72);
  const dark  = hexDarken(hex, 0.42);
  const vdark = hexDarken(hex, 0.28);
  return `linear-gradient(${dir}deg, ${hex} 0%, ${mid} 40%, ${dark} 70%, ${vdark} 100%)`;
}
function onColorChange() {
  const hc = document.getElementById('home-color').value;
  const ac = document.getElementById('away-color').value;

  // update swatches
  document.getElementById('home-swatch').style.background = hc;
  document.getElementById('away-swatch').style.background = ac;
  document.getElementById('home-hex-lbl').textContent = hc.toUpperCase();
  document.getElementById('away-hex-lbl').textContent = ac.toUpperCase();

  // update CSS vars on the canvas
  const oc = document.getElementById('oc');
  oc.style.setProperty('--home-color', hc);
  oc.style.setProperty('--away-color', ac);
  oc.style.setProperty('--home-grad', buildGrad(hc, 118));
  oc.style.setProperty('--away-grad', buildGrad(ac, 242));

}

function onBarColorChange() {
  const hb = document.getElementById('home-bar-color').value;
  const ab = document.getElementById('away-bar-color').value;
  document.getElementById('home-bar-swatch').style.background = hb;
  document.getElementById('away-bar-swatch').style.background = ab;
  // auto text color for swatch label
  document.getElementById('home-bar-hex-lbl').style.color = isLight(hb) ? '#000' : '#fff';
  document.getElementById('away-bar-hex-lbl').style.color = isLight(ab) ? '#000' : '#fff';
  document.getElementById('home-bar-hex-lbl').textContent = hb.toUpperCase();
  document.getElementById('away-bar-hex-lbl').textContent = ab.toUpperCase();
  const oc = document.getElementById('oc');
  oc.style.setProperty('--home-bar', hb);
  oc.style.setProperty('--away-bar', ab);
}

function isLight(hex) {
  const r=parseInt(hex.slice(1,3),16), g=parseInt(hex.slice(3,5),16), b=parseInt(hex.slice(5,7),16);
  return (r*299+g*587+b*114)/1000 > 128;
}

/* ═══════════════════════════════════════════════════════════════
   SYNC TEXT CONTENT
═══════════════════════════════════════════════════════════════ */
function syncContent() {
  const hn = (document.getElementById('home-name').value||'TEAM ABC').toUpperCase();
  const an = (document.getElementById('away-name').value||'TEAM DEF').toUpperCase();
  const ha = (document.getElementById('home-abbr').value||'ABC').toUpperCase();
  const aa = (document.getElementById('away-abbr').value||'DEF').toUpperCase();
  const lc =  document.getElementById('loc-text').value||'Live from Selangor Polo Club';
  const hs = S.homeScore, as_ = S.awayScore, per = S.period;

  const set = (id, v) => { const el=document.getElementById(id); if(el) el.textContent=v; };

  set('intro-h-name', hn);  set('intro-a-name', an);  set('intro-loc', lc);
  // Auto-shrink intro name text to fit card width
  requestAnimationFrame(() => {
    ['intro-h-name','intro-a-name'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      const card = el.closest('.ic');
      if (!card) return;
      let size = 72;
      el.style.fontSize = size + 'px';
      // shrink until text fits within card padding area (card width - 64px padding)
      const maxW = card.clientWidth - 64;
      while (el.scrollWidth > maxW && size > 28) {
        size -= 2;
        el.style.fontSize = size + 'px';
      }
    });
  });
  set('match-h', hn);       set('match-a', an);        set('match-loc', lc);
  set('sbug-h',  hn);       set('sbug-a',  an);        set('sbug-loc',  lc);
  set('sbug-hs', hs);       set('sbug-as', as_);
  set('sb-ha',   ha);       set('sb-aa',   aa);
  set('sb-hs',   hs);       set('sb-as',   as_);
  set('sb-period', per);
}

/* ═══════════════════════════════════════════════════════════════
   SHOW / HIDE  — restart animations cleanly via reflow trick
═══════════════════════════════════════════════════════════════ */
function show(id) {
  syncContent();
  const el = document.getElementById('g-' + id);
  if (!el) return;
  // 1. Remove both state classes
  el.classList.remove('on','out');
  // 2. Force reflow so browser forgets animation state
  void el.offsetWidth;
  // 3. Make visible + add entry class
  el.classList.add('on');
  S.live.add(id);
  updateStatus();
}

function hide(id) {
  const el = document.getElementById('g-' + id);
  if (!el || !el.classList.contains('on')) return;
  // Switch to exit animation
  el.classList.remove('on');
  void el.offsetWidth;
  el.classList.add('out');
  // Remove visibility after exit duration (~380ms)
  setTimeout(() => {
    el.classList.remove('out');
  }, 420);
  S.live.delete(id);
  updateStatus();
}

function hideAll() {
  ['intro','match','scorebug','scoreboard'].forEach(hide);
}

/* ═══════════════════════════════════════════════════════════════
   SCORE
═══════════════════════════════════════════════════════════════ */
function adj(side, d) {
  if (side==='home') S.homeScore = Math.max(0, S.homeScore+d);
  else               S.awayScore = Math.max(0, S.awayScore+d);
  document.getElementById('home-score-val').textContent = S.homeScore;
  document.getElementById('away-score-val').textContent = S.awayScore;
  syncContent();
  // flash score elements without breaking the resting scale(1) state
  ['sb-hs','sb-as','sbug-hs','sbug-as'].forEach(sid => {
    const el = document.getElementById(sid);
    if (!el) return;
    el.classList.remove('score-flash');
    void el.offsetWidth;
    el.classList.add('score-flash');
    setTimeout(() => el.classList.remove('score-flash'), 400);
  });
}

/* ═══════════════════════════════════════════════════════════════
   PERIOD
═══════════════════════════════════════════════════════════════ */
document.getElementById('pills').addEventListener('click', e => {
  const pill = e.target.closest('.pill');
  if (!pill) return;
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('act'));
  pill.classList.add('act');
  S.period = pill.dataset.v;
  syncContent();
});

/* ═══════════════════════════════════════════════════════════════
   CLOCK
═══════════════════════════════════════════════════════════════ */
function fmt() { return String(S.mm).padStart(2,'0')+':'+String(S.ss).padStart(2,'0'); }
function clockTick() {
  S.ss++;
  if(S.ss>=60){S.ss=0;S.mm++;}
  const s=fmt();
  document.getElementById('clock-face').textContent=s;
  document.getElementById('sb-clock').textContent=s;
}
function toggleClock() {
  const btn=document.getElementById('btn-ss');
  if(S.running){
    clearInterval(S.iv); S.running=false;
    btn.textContent='▶ Start'; btn.classList.remove('running');
  } else {
    S.running=true; S.iv=setInterval(clockTick,1000);
    btn.textContent='⏸ Pause'; btn.classList.add('running');
  }
}
function resetClock() {
  clearInterval(S.iv); S.running=false; S.mm=0; S.ss=0;
  document.getElementById('btn-ss').textContent='▶ Start';
  document.getElementById('btn-ss').classList.remove('running');
  const s=fmt();
  document.getElementById('clock-face').textContent=s;
  document.getElementById('sb-clock').textContent=s;
}
function setClock() {
  const v=prompt('Enter time MM:SS (e.g. 04:30):',fmt());
  if(!v)return;
  const m=v.match(/^(\d{1,2}):(\d{2})$/);
  if(!m){alert('Format: MM:SS');return;}
  S.mm=parseInt(m[1]); S.ss=parseInt(m[2]);
  const s=fmt();
  document.getElementById('clock-face').textContent=s;
  document.getElementById('sb-clock').textContent=s;
}

/* ═══════════════════════════════════════════════════════════════
   STATUS
═══════════════════════════════════════════════════════════════ */
function updateStatus() {
  const dot=document.getElementById('sdot'), lbl=document.getElementById('slabel');
  if(S.live.size>0){ dot.classList.add('live'); lbl.textContent='LIVE'; }
  else{ dot.classList.remove('live'); lbl.textContent='STANDBY'; }
}

/* ═══════════════════════════════════════════════════════════════
   STREAM VIEW  — clones the canvas to a full-screen overlay
═══════════════════════════════════════════════════════════════ */
function enterStreamView() {
  // Clone the overlay canvas into the fullscreen div
  const oc = document.getElementById('oc');
  const fsc = document.getElementById('fs-canvas');
  // Remove any old clone
  while(fsc.firstChild) fsc.removeChild(fsc.firstChild);
  const clone = oc.cloneNode(true);
  // Remove scaling style so it fills the screen
  clone.style.transform = '';
  clone.style.left = '';
  clone.style.top  = '';
  clone.style.position = 'absolute';
  clone.style.top = '50%';
  clone.style.left = '50%';
  // Scale to fit viewport
  const scale = Math.min(window.innerWidth/1920, window.innerHeight/1080);
  clone.style.transformOrigin = 'center center';
  clone.style.transform = `translate(-50%, -50%) scale(${scale})`;
  fsc.appendChild(clone);
  document.body.classList.add('sv');
  // Keep syncing content to both canvases
  window._svMode = true;
  syncContent();
  onColorChange();
}
function exitStreamView() {
  document.body.classList.remove('sv');
  window._svMode = false;
  // Clear fs-canvas
  const fsc = document.getElementById('fs-canvas');
  while(fsc.firstChild) fsc.removeChild(fsc.firstChild);
}

/* ═══════════════════════════════════════════════════════════════
   OVERRIDE syncContent to also update fs-canvas clone
═══════════════════════════════════════════════════════════════ */
const _origSync = syncContent;
// wrap show() to also trigger clone in stream view if active
const _origShow = show;
// We instead just re-enter stream view on each show to keep clone fresh
// Simpler: use CSS custom properties + DOM shared IDs
// Actually the cleanest approach: DON'T clone. Instead make fs-canvas
// display the SAME oc div by moving it, not cloning.
// Revised stream view: just hide #app and scale #oc to fullscreen.

/* Cleaner stream view approach - just move/scale the real canvas */
function enterStreamView() {
  const oc   = document.getElementById('oc');
  const pane = document.getElementById('preview-pane');

  // Detach oc from preview-pane, attach to fs-canvas
  const fsc = document.getElementById('fs-canvas');
  fsc.appendChild(oc);

  // Size it
  oc.style.position = 'absolute';
  oc.style.transformOrigin = 'center center';
  oc.style.left = '50%';
  oc.style.top  = '50%';
  const scale = Math.min(window.innerWidth/1920, window.innerHeight/1080);
  oc.style.transform = `translate(-50%,-50%) scale(${scale})`;

  document.body.classList.add('sv');
}
function exitStreamView() {
  const oc   = document.getElementById('oc');
  const pane = document.getElementById('preview-pane');

  // Move oc back to preview-pane
  pane.appendChild(oc);
  document.body.classList.remove('sv');

  // Restore preview scaling
  oc.style.position = 'absolute';
  oc.style.left = '';
  oc.style.top  = '';
  oc.style.transform = '';
  oc.style.transformOrigin = 'top left';
  scaleOC();
}
window.addEventListener('resize', () => {
  if(document.body.classList.contains('sv')) {
    const oc = document.getElementById('oc');
    const scale = Math.min(window.innerWidth/1920, window.innerHeight/1080);
    oc.style.transform = `translate(-50%,-50%) scale(${scale})`;
  } else {
    scaleOC();
  }
});

/* ═══════════════════════════════════════════════════════════════
   KEYBOARD SHORTCUTS
═══════════════════════════════════════════════════════════════ */
document.addEventListener('keydown', e => {
  if(e.target.tagName==='INPUT') return;
  switch(e.key) {
    case '1': show('intro');      break;
    case '2': show('match');      break;
    case '3': show('scorebug');   break;
    case '4': show('scoreboard'); break;
    case 'Escape': hideAll();     break;
    case ' ': e.preventDefault(); toggleClock(); break;
    case '+': case '=': adj('home',+1); break;
    case '-': adj('home',-1); break;
    case ']': adj('away',+1); break;
    case '[': adj('away',-1); break;
  }
});


/* ═══════════════════════════════════════════════════════════════
   TRANSFORM: per-graphic position + scale
═══════════════════════════════════════════════════════════════ */
const xforms = {
  intro:      {x:0, y:0, s:100},
  match:      {x:0, y:0, s:100},
  scorebug:   {x:0, y:0, s:100},
  scoreboard: {x:0, y:0, s:100},
};

function applyXform(id, input, axis) {
  const val = parseFloat(input.value);
  xforms[id][axis] = val;
  document.getElementById(id+'-'+axis+'v').textContent = axis==='s' ? val : val;
  updateGTransform(id);
}

function updateGTransform(id) {
  const el = document.getElementById('g-' + id);
  if (!el) return;
  const {x, y, s} = xforms[id];
  el.style.transform = `translate(${x}px, ${y}px) scale(${s/100})`;
  el.style.transformOrigin = 'center center';
}

function resetXform(id) {
  xforms[id] = {x:0, y:0, s:100};
  document.getElementById(id+'-x').value = 0;
  document.getElementById(id+'-y').value = 0;
  document.getElementById(id+'-s').value = 100;
  document.getElementById(id+'-xv').textContent = 0;
  document.getElementById(id+'-yv').textContent = 0;
  document.getElementById(id+'-sv').textContent = 100;
  updateGTransform(id);
}


function copyServer() {
  const cmd = document.getElementById('server-cmd').textContent;
  navigator.clipboard.writeText(cmd).then(() => {
    const msg = document.getElementById('copy-msg');
    msg.style.opacity = '1';
    setTimeout(() => msg.style.opacity = '0', 2000);
  }).catch(() => {
    // fallback for file:// protocol
    const ta = document.createElement('textarea');
    ta.value = cmd; document.body.appendChild(ta);
    ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
    const msg = document.getElementById('copy-msg');
    msg.style.opacity = '1';
    setTimeout(() => msg.style.opacity = '0', 2000);
  });
}

/* init */
syncContent();
onColorChange();
onBarColorChange();
scaleOC();
</script>
</body>
</html>
